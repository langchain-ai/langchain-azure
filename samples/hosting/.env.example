# Copy this file to `.env` and fill in your values.
# Real shell environment variables take precedence over values set here.

# Required: Azure AI Foundry project endpoint.
# Example: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# Optional: deployment name of the chat model to use. Defaults to "gpt-4o".
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Required for sample_07_responses_toolbox.py: name of the toolbox
# configured in your Azure AI Foundry project.
FOUNDRY_AGENT_TOOLBOX_NAME=

# Required for sample_09_responses_foundry_memory.py: deployment names
# the Foundry Memory Store uses internally for fact extraction and
# semantic indexing. These are read only once, when the Memory Store is
# first created.
MEMORY_STORE_CHAT_MODEL_DEPLOYMENT_NAME=gpt-4o
MEMORY_STORE_EMBEDDING_MODEL_DEPLOYMENT_NAME=text-embedding-3-large

# Optional for sample_09_responses_foundry_memory.py.
# MEMORY_STORE_NAME: name of the Memory Store inside your Foundry
#   project. Defaults to "langchain-azure-ai-demo-store".
# MEMORY_USER_SCOPE: stable identifier that partitions long-term memory
#   per user/tenant. Defaults to "user:demo-user". In production this
#   should be derived from the authenticated user (e.g. "user:{sub}").
#MEMORY_STORE_NAME=langchain-azure-ai-demo-store
#MEMORY_USER_SCOPE=user:demo-user

# ---------------------------------------------------------------------------
# Tracing (optional) — destination is selected by env vars only, no code
# changes needed. First matching rule wins, top to bottom:
#
#   0. OTEL_SDK_DISABLED=true       -> tracing fully off
#   1. OTEL_EXPORTER_OTLP_TRACES_ENDPOINT (or OTEL_EXPORTER_OTLP_ENDPOINT)
#                                   -> OTLP/HTTP collector at that URL
#   2. APPLICATION_INSIGHTS_CONNECTION_STRING
#                                   -> Azure Monitor directly
#   3. AZURE_AI_PROJECT_ENDPOINT (already set above)
#                                   -> Foundry project's managed App Insights
#                                      (connection string is auto-resolved;
#                                      requires az login + Reader on project)
#   4. (none of the above)          -> tracer attached but no exporter
#
# Set AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true to include actual
# message text, tool arguments, and tool results in spans (default: redacted).
# ---------------------------------------------------------------------------
#OTEL_SDK_DISABLED=true
#OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
#APPLICATION_INSIGHTS_CONNECTION_STRING=
#OTEL_SERVICE_NAME=langchain-azure-hosting-sample
#AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true
